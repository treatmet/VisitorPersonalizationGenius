        "ctaText": "Create a Business Sign Up",
        "ctaUrl": "/register?template=business"
      },
      "theme": { "variant": "professional-gray" }
    },
    "homepage_default": {
      "hero": {
        "headline": "Plan together with sign ups that just work",
        "subheadline": "Millions of people use SignUpGenius to simplify event planning.",
        "ctaText": "Create a Free Sign Up",
        "ctaUrl": "/register"
      },
      "theme": { "variant": "default" }
    }
  },

  "defaultContent": {
    "hero": {
      "headline": "Plan together with sign ups that just work",
